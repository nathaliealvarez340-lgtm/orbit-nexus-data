generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleKey {
  SUPERADMIN
  LEADER
  CONSULTANT
  CLIENT
}

enum UserStatus {
  PENDING_REGISTRATION
  ACTIVE
  DISABLED
}

enum CompanyPlan {
  CORE
  GROWTH
  ENTERPRISE
}

enum CompanyBillingStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  ENTERPRISE_REVIEW
}

enum ProjectStatus {
  DRAFT
  READY_FOR_MATCHING
  MATCHING_IN_PROGRESS
  ASSIGNED
  ACTIVE
  UNDER_REVIEW
  AT_RISK
  AUDIT_IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BadgeCategory {
  COMPLIANCE
  QUALITY
  SPEED
  TRUST
}

enum AssignmentMode {
  SMART
  MANUAL
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  REJECTED
  MANUAL_LOCKED
  COMPLETED
}

enum ProgressStatus {
  PENDING
  DELIVERED
  LATE
  COMMENTED
  CORRECTED
}

enum NotificationType {
  SYSTEM
  AUTH
  PROJECT
  INCIDENT
  AUDIT
}

enum IncidentType {
  MISSED_DELIVERY
  WARNING
  ESCALATED_TO_AUDIT
}

enum IncidentStatus {
  OPEN
  WARNING
  AUDIT_SCHEDULED
  CLOSED
}

enum AuditStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum LoginStatus {
  SUCCESS
  FAILED
}

enum ReviewStatus {
  PUBLISHED
  HIDDEN
}

enum ChatThreadStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum MessageType {
  TEXT
  SYSTEM
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum ContractAcceptanceStatus {
  CONTRACT_SIGNED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SupportTicketSource {
  NEXUS_CHAT
  CONTACT
  SYSTEM
}

enum RejectionReason {
  CAPACITY
  TIMELINE_CONFLICT
  SCOPE_MISMATCH
  SKILL_MISMATCH
  PRIORITY_CONFLICT
  OTHER
}

model Company {
  id                          String                       @id @default(cuid())
  name                        String
  slug                        String                       @unique
  codePrefix                  String                       @unique
  registrationCode            String                       @unique
  isActive                    Boolean                      @default(true)
  sector                      String?
  contactName                 String?
  contactEmail                String?
  subscriptionPlan            CompanyPlan?
  includedUsers               Int                          @default(0)
  extraUsers                  Int                          @default(0)
  monthlyAmountMxn            Int?
  billingStatus               CompanyBillingStatus         @default(PENDING)
  stripeCustomerId            String?                      @unique
  stripeSubscriptionId        String?                      @unique
  stripeCheckoutSessionId     String?                      @unique
  activatedAt                 DateTime?
  users                       User[]
  skills                      Skill[]
  userSkills                  UserSkill[]
  consultantKpis              ConsultantKpi[]
  userBadges                  UserBadge[]
  reviews                     Review[]
  projects                    Project[]
  projectSkills               ProjectSkill[]
  projectAssignments          ProjectAssignment[]
  projectAssignmentRejections ProjectAssignmentRejection[]
  progressEntries             Progress[]
  comments                    Comment[]
  notifications               Notification[]
  chatThreads                 ChatThread[]
  chatMessages                ChatMessage[]
  incidents                   Incident[]
  audits                      Audit[]
  meetings                    Meeting[]
  projectStatusHistory        ProjectStatusHistory[]
  loginActivities             LoginActivity[]
  activationRequests          CompanyActivationRequest[]
  contractAcceptances         ContractAcceptance[]
  supportTickets              SupportTicket[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt

  @@map("companies")
}

model CompanyActivationRequest {
  id                    String               @id @default(cuid())
  companyId             String?
  fullName              String
  email                 String
  companyName           String
  sector                String
  plan                  CompanyPlan
  includedUsers         Int
  extraUsers            Int                  @default(0)
  totalAmountMxn        Int
  status                CompanyBillingStatus @default(PENDING)
  stripeCheckoutSessionId String?            @unique
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  registrationCode      String?
  companySlug           String
  companyCodePrefix     String
  company               Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([status, createdAt])
  @@map("company_activation_requests")
}

model Role {
  id              String          @id @default(cuid())
  key             RoleKey         @unique
  name            String
  description     String?
  users           User[]
  loginActivities LoginActivity[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("roles")
}

model User {
  id                              String                       @id @default(cuid())
  companyId                       String?
  roleId                          String
  createdByLeaderId               String?
  fullName                        String
  normalizedFullName              String
  email                           String
  phone                           String?
  specializationSummary           String?
  passwordHash                    String?
  accessCode                      String?                      @unique
  status                          UserStatus                   @default(PENDING_REGISTRATION)
  importedFromDirectory           Boolean                      @default(false)
  directorySyncedAt               DateTime?
  registeredAt                    DateTime?
  disabledAt                      DateTime?
  company                         Company?                     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  role                            Role                         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdProjects                 Project[]                    @relation("LeaderProjects")
  clientProjects                  Project[]                    @relation("ProjectClient")
  consultantAssignments           ProjectAssignment[]          @relation("ConsultantProjectAssignments")
  consultantAssignmentRejections  ProjectAssignmentRejection[] @relation("ConsultantAssignmentRejections")
  consultantProgress              Progress[]                   @relation("ConsultantProgress")
  consultantKpiRecords            ConsultantKpi[]              @relation("ConsultantKpiRecords")
  userSkills                      UserSkill[]
  earnedBadges                    UserBadge[]                  @relation("EarnedUserBadges")
  awardedBadges                   UserBadge[]                  @relation("AwardedByUserBadges")
  authoredReviews                 Review[]                     @relation("ReviewerReviews")
  receivedReviews                 Review[]                     @relation("RevieweeReviews")
  authoredComments                Comment[]                    @relation("AuthorComments")
  notifications                   Notification[]
  consultantChatThreads           ChatThread[]                 @relation("ConsultantChatThreads")
  clientChatThreads               ChatThread[]                 @relation("ClientChatThreads")
  sentMessages                    ChatMessage[]                @relation("SenderMessages")
  projectStatusChanges            ProjectStatusHistory[]       @relation("ProjectStatusChangedBy")
  scheduledAudits                 Audit[]                      @relation("ScheduledAudits")
  meetingsScheduled               Meeting[]                    @relation("MeetingsScheduledBy")
  loginActivities                 LoginActivity[]
  createdAt                       DateTime                     @default(now())
  updatedAt                       DateTime                     @updatedAt

  @@unique([companyId, roleId, email])
  @@unique([id, companyId])
  @@index([companyId, roleId])
  @@index([normalizedFullName, email])
  @@map("users")
}

model Project {
  id                          String                       @id @default(cuid())
  companyId                   String
  leaderId                    String?
  clientUserId                String?
  clientContactName           String?
  clientContactEmail          String?
  name                        String
  description                 String
  durationLabel               String
  startDate                   DateTime?
  endDate                     DateTime?
  requirements                Json?
  priority                    ProjectPriority              @default(MEDIUM)
  folio                       String                       @unique
  status                      ProjectStatus                @default(DRAFT)
  statusChangedAt             DateTime                     @default(now())
  company                     Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leader                      User?                        @relation("LeaderProjects", fields: [leaderId, companyId], references: [id, companyId], onDelete: Cascade)
  clientUser                  User?                        @relation("ProjectClient", fields: [clientUserId, companyId], references: [id, companyId], onDelete: Cascade)
  projectSkills               ProjectSkill[]
  projectAssignments          ProjectAssignment[]
  projectAssignmentRejections ProjectAssignmentRejection[]
  progressEntries             Progress[]
  comments                    Comment[]
  notifications               Notification[]
  reviews                     Review[]
  chatThreads                 ChatThread[]
  incidents                   Incident[]
  audits                      Audit[]
  meetings                    Meeting[]
  statusHistory               ProjectStatusHistory[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt

  @@unique([id, companyId])
  @@index([companyId, status])
  @@map("projects")
}

model ProjectAssignment {
  id                         String                       @id @default(cuid())
  companyId                  String
  projectId                  String
  consultantId               String
  mode                       AssignmentMode               @default(SMART)
  status                     AssignmentStatus             @default(PENDING)
  rejectionCount             Int                          @default(0)
  assignedAt                 DateTime                     @default(now())
  acceptedAt                 DateTime?
  lastRejectedAt             DateTime?
  manualAssignmentRequiredAt DateTime?
  manualAssignmentLockedAt   DateTime?
  company                    Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project                    Project                      @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  consultant                 User                         @relation("ConsultantProjectAssignments", fields: [consultantId, companyId], references: [id, companyId], onDelete: Restrict)
  rejections                 ProjectAssignmentRejection[]
  reviews                    Review[]
  chatThreads                ChatThread[]
  incidents                  Incident[]
  progressEntries            Progress[]
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt

  @@unique([id, companyId])
  @@unique([projectId, consultantId])
  @@index([companyId, status])
  @@map("project_assignments")
}

model Skill {
  id            String         @id @default(cuid())
  companyId     String
  name          String
  slug          String
  category      String?
  description   String?
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userSkills    UserSkill[]
  projectSkills ProjectSkill[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([companyId, slug])
  @@unique([id, companyId])
  @@map("skills")
}

model UserSkill {
  id                 String    @id @default(cuid())
  companyId          String
  userId             String
  skillId            String
  proficiencyPercent Int
  yearsExperience    Float?
  isPrimary          Boolean   @default(false)
  notes              String?
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId, companyId], references: [id, companyId], onDelete: Cascade)
  skill              Skill     @relation(fields: [skillId, companyId], references: [id, companyId], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([userId, skillId])
  @@index([companyId, userId])
  @@map("user_skills")
}

model ProjectSkill {
  id                 String    @id @default(cuid())
  companyId          String
  projectId          String
  skillId            String
  minimumProficiency Int       @default(60)
  importanceWeight   Int       @default(1)
  isRequired         Boolean   @default(true)
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project            Project   @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  skill              Skill     @relation(fields: [skillId, companyId], references: [id, companyId], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([projectId, skillId])
  @@index([companyId, projectId])
  @@map("project_skills")
}

model ConsultantKpi {
  id                     String    @id @default(cuid())
  companyId              String
  consultantId           String
  complianceScore        Float     @default(0)
  qualityScore           Float     @default(0)
  speedScore             Float     @default(0)
  trustScore             Float     @default(0)
  overallScore           Float     @default(0)
  activeProjectsCount    Int       @default(0)
  completedProjectsCount Int       @default(0)
  incidentsCount         Int       @default(0)
  lastCalculatedAt       DateTime?
  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  consultant             User      @relation("ConsultantKpiRecords", fields: [consultantId, companyId], references: [id, companyId], onDelete: Cascade)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([consultantId, companyId])
  @@index([companyId, overallScore])
  @@map("consultant_kpis")
}

model UserBadge {
  id          String        @id @default(cuid())
  companyId   String
  userId      String
  category    BadgeCategory
  awardedById String?
  note        String?
  awardedAt   DateTime      @default(now())
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User          @relation("EarnedUserBadges", fields: [userId, companyId], references: [id, companyId], onDelete: Cascade)
  awardedBy   User?         @relation("AwardedByUserBadges", fields: [awardedById, companyId], references: [id, companyId], onDelete: Cascade)

  @@unique([userId, category])
  @@index([companyId, userId])
  @@map("user_badges")
}

model Review {
  id           String             @id @default(cuid())
  companyId    String
  projectId    String
  assignmentId String?
  reviewerId   String
  revieweeId   String
  rating       Int
  comment      String?
  status       ReviewStatus       @default(PUBLISHED)
  submittedAt  DateTime           @default(now())
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project      Project            @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  assignment   ProjectAssignment? @relation(fields: [assignmentId, companyId], references: [id, companyId], onDelete: Cascade)
  reviewer     User               @relation("ReviewerReviews", fields: [reviewerId, companyId], references: [id, companyId], onDelete: Cascade)
  reviewee     User               @relation("RevieweeReviews", fields: [revieweeId, companyId], references: [id, companyId], onDelete: Cascade)

  @@index([companyId, revieweeId])
  @@index([companyId, projectId])
  @@map("reviews")
}

model ChatThread {
  id            String             @id @default(cuid())
  companyId     String
  projectId     String
  assignmentId  String?
  consultantId  String
  clientId      String
  title         String?
  status        ChatThreadStatus   @default(ACTIVE)
  lastMessageAt DateTime?
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project       Project            @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  assignment    ProjectAssignment? @relation(fields: [assignmentId, companyId], references: [id, companyId], onDelete: Cascade)
  consultant    User               @relation("ConsultantChatThreads", fields: [consultantId, companyId], references: [id, companyId], onDelete: Cascade)
  client        User               @relation("ClientChatThreads", fields: [clientId, companyId], references: [id, companyId], onDelete: Cascade)
  messages      ChatMessage[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([id, companyId])
  @@unique([projectId, consultantId, clientId])
  @@index([companyId, projectId])
  @@map("chat_threads")
}

model ChatMessage {
  id         String      @id @default(cuid())
  companyId  String
  threadId   String
  senderId   String
  content    String
  type       MessageType @default(TEXT)
  sentAt     DateTime    @default(now())
  editedAt   DateTime?
  deletedAt  DateTime?
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  thread     ChatThread  @relation(fields: [threadId, companyId], references: [id, companyId], onDelete: Cascade)
  sender     User        @relation("SenderMessages", fields: [senderId, companyId], references: [id, companyId], onDelete: Cascade)

  @@index([companyId, threadId, sentAt])
  @@map("chat_messages")
}

model ProjectStatusHistory {
  id          String         @id @default(cuid())
  companyId   String
  projectId   String
  changedById String?
  fromStatus  ProjectStatus?
  toStatus    ProjectStatus
  note        String?
  changedAt   DateTime       @default(now())
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project     Project        @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  changedBy   User?          @relation("ProjectStatusChangedBy", fields: [changedById, companyId], references: [id, companyId], onDelete: Cascade)

  @@index([companyId, projectId, changedAt])
  @@map("project_status_history")
}

model Progress {
  id            String             @id @default(cuid())
  companyId     String
  projectId     String
  assignmentId  String?
  consultantId  String
  title         String
  fileName      String
  fileUrl       String
  dueAt         DateTime?
  submittedAt   DateTime?
  status        ProgressStatus     @default(PENDING)
  feedback      String?
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project       Project            @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  assignment    ProjectAssignment? @relation(fields: [assignmentId, companyId], references: [id, companyId], onDelete: Cascade)
  consultant    User               @relation("ConsultantProgress", fields: [consultantId, companyId], references: [id, companyId], onDelete: Restrict)
  comments      Comment[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([id, companyId])
  @@index([companyId, status])
  @@map("progress")
}

model Comment {
  id           String    @id @default(cuid())
  companyId    String
  projectId    String
  progressId   String?
  authorId     String
  content      String
  selectedText String?
  pageNumber   Int?
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project      Project   @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  progress     Progress? @relation(fields: [progressId, companyId], references: [id, companyId], onDelete: Cascade)
  author       User      @relation("AuthorComments", fields: [authorId, companyId], references: [id, companyId], onDelete: Restrict)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId, projectId])
  @@map("comments")
}

model Notification {
  id        String           @id @default(cuid())
  companyId String
  userId    String
  projectId String?
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  readAt    DateTime?
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId, companyId], references: [id, companyId], onDelete: Cascade)
  project   Project?         @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([companyId, userId])
  @@map("notifications")
}

model Incident {
  id              String             @id @default(cuid())
  companyId       String
  projectId       String
  assignmentId    String?
  type            IncidentType
  status          IncidentStatus     @default(OPEN)
  warningIssuedAt DateTime?
  auditEligibleAt DateTime?
  closedAt        DateTime?
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project         Project            @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  assignment      ProjectAssignment? @relation(fields: [assignmentId, companyId], references: [id, companyId], onDelete: Cascade)
  audits          Audit[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([id, companyId])
  @@index([companyId, status])
  @@map("incidents")
}

model Audit {
  id            String      @id @default(cuid())
  companyId     String
  projectId     String
  incidentId    String?
  scheduledById String?
  scheduledAt   DateTime?
  message       String?
  meetingLink   String?
  status        AuditStatus @default(PENDING)
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  incident      Incident?   @relation(fields: [incidentId, companyId], references: [id, companyId], onDelete: Cascade)
  scheduledBy   User?       @relation("ScheduledAudits", fields: [scheduledById, companyId], references: [id, companyId], onDelete: Cascade)
  meetings      Meeting[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([id, companyId])
  @@index([companyId, status])
  @@map("audits")
}

model Meeting {
  id            String        @id @default(cuid())
  companyId     String
  projectId     String
  auditId       String?
  scheduledById String?
  title         String
  description   String?
  startsAt      DateTime
  endsAt        DateTime?
  meetingUrl    String?
  notes         String?
  status        MeetingStatus @default(SCHEDULED)
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project       Project       @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  audit         Audit?        @relation(fields: [auditId, companyId], references: [id, companyId], onDelete: Cascade)
  scheduledBy   User?         @relation("MeetingsScheduledBy", fields: [scheduledById, companyId], references: [id, companyId], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([id, companyId])
  @@index([companyId, projectId, startsAt])
  @@map("meetings")
}

model ProjectAssignmentRejection {
  id                        String            @id @default(cuid())
  companyId                 String
  projectId                 String
  assignmentId              String
  consultantId              String
  rejectionNumber           Int
  reason                    RejectionReason
  detail                    String?
  rejectedAt                DateTime          @default(now())
  triggeredManualAssignment Boolean           @default(false)
  company                   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project                   Project           @relation(fields: [projectId, companyId], references: [id, companyId], onDelete: Cascade)
  assignment                ProjectAssignment @relation(fields: [assignmentId, companyId], references: [id, companyId], onDelete: Cascade)
  consultant                User              @relation("ConsultantAssignmentRejections", fields: [consultantId, companyId], references: [id, companyId], onDelete: Cascade)

  @@unique([assignmentId, rejectionNumber])
  @@index([companyId, consultantId])
  @@map("project_assignment_rejections")
}

model LoginActivity {
  id                String      @id @default(cuid())
  userId            String?
  roleId            String?
  companyId         String?
  accessCodeAttempt String?
  ipAddress         String?
  device            String?
  status            LoginStatus
  failureReason     String?
  user              User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  role              Role?       @relation(fields: [roleId], references: [id], onDelete: SetNull)
  company           Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  occurredAt        DateTime    @default(now())

  @@index([companyId, occurredAt])
  @@index([accessCodeAttempt])
  @@map("login_activity")
}

model ContractAcceptance {
  id                String                   @id @default(cuid())
  companyId         String?
  projectId         String?
  projectExternalId String
  projectSlug       String
  projectName       String
  assignmentId      String?
  consultantUserId  String?
  consultantName    String
  leaderUserId      String?
  leaderName        String?
  companyName       String?
  contractVersion   String                   @default("v1")
  contractTitle     String
  contractBody      String
  status            ContractAcceptanceStatus @default(CONTRACT_SIGNED)
  signedAt          DateTime                 @default(now())
  company           Company?                 @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([companyId, signedAt])
  @@index([projectSlug, consultantUserId])
  @@map("contract_acceptances")
}

model SupportTicket {
  id             String                @id @default(cuid())
  companyId      String?
  source         SupportTicketSource   @default(NEXUS_CHAT)
  status         SupportTicketStatus   @default(OPEN)
  priority       SupportTicketPriority @default(MEDIUM)
  userId         String?
  userRole       RoleKey
  userName       String
  title          String
  message        String
  contextLabel   String
  routePath      String
  assistantReply String?
  resolvedAt     DateTime?
  resolvedBy     String?
  company        Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([companyId, createdAt])
  @@index([status, priority, createdAt])
  @@map("support_tickets")
}

model PricingSetting {
  id                   String   @id @default(cuid())
  coreMonthlyMxn       Int
  growthMonthlyMxn     Int
  extraUserMonthlyMxn  Int
  enterpriseStartingUsd Int
  updatedByName        String?
